generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Image {
  id        String   @id @default(cuid())
  driveId   String   @unique
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tags      Tag[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  images    Image[]
}
